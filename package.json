{
  "name": "@uikode/tide",
  "version": "1.1.1",
  "description": "WebSocket-first, stale-while-revalidate data framework for SolidJS. Data flows. UI follows.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./skeleton": {
      "types": "./dist/skeleton/index.d.ts",
      "import": "./dist/skeleton/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.9.2",
    "jsdom": "^29.1.1",
    "solid-js": "^1.9.13",
    "tsup": "^8.0.0",
    "tsup-preset-solid": "^2.2.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "solidjs",
    "swr",
    "stale-while-revalidate",
    "websocket",
    "cache",
    "realtime",
    "data-fetching",
    "skeleton",
    "dashboard"
  ],
  "author": "Andy Vandaric <andy@uikode.com>",
  "license": "MIT",
  "homepage": "https://uikode.com/tide",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uikode/tide.git"
  },
  "bugs": {
    "url": "https://github.com/uikode/tide/issues"
  }
}
